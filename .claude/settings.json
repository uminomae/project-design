{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(bash scripts/*)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(python3 *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *.md)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(git push origin develop)",
      "Bash(git push origin main)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(rm *.html)",
      "Bash(rm *.json)",
      "Bash(git worktree *)",
      "Bash(git rm *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(rm -rf *)",
      "Bash(rm -r /)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(chmod 777 *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-guard.sh",
            "timeout": 10,
            "statusMessage": "Session start checks..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/wiki-gen-check.sh",
            "timeout": 15,
            "statusMessage": "Wiki generation check..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ui-lint.sh",
            "timeout": 10,
            "statusMessage": "UI lint checking..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/wiki-build.sh",
            "timeout": 45,
            "statusMessage": "Wiki build..."
          }
        ]
      }
    ]
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        ".claude/settings.json"
      ]
    }
  }
}
